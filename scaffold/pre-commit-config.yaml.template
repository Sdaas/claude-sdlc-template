repos:
  # ---------------------------------------------------------------------------
  # Ruff — lint and format (replaces flake8, isort, black)
  # ---------------------------------------------------------------------------
  - repo: https://github.com/astral-sh/ruff-pre-commit
    rev: v0.4.4
    hooks:
      - id: ruff
        args: [--fix]
      - id: ruff-format

  # ---------------------------------------------------------------------------
  # Mypy — static type checking
  # ---------------------------------------------------------------------------
  - repo: https://github.com/pre-commit/mirrors-mypy
    rev: v1.10.0
    hooks:
      - id: mypy
        args: [--strict]
        additional_dependencies: [types-all]

  # ---------------------------------------------------------------------------
  # Shellcheck — shell script linting
  # ---------------------------------------------------------------------------
  - repo: https://github.com/shellcheck-py/shellcheck-py
    rev: v0.10.0.1
    hooks:
      - id: shellcheck
        files: ^scripts/.*\.sh$

  # ---------------------------------------------------------------------------
  # Sqlfluff — SQL linting
  # ---------------------------------------------------------------------------
  - repo: https://github.com/sqlfluff/sqlfluff
    rev: 3.0.7
    hooks:
      - id: sqlfluff-lint
        files: ^sql/.*\.sql$
      - id: sqlfluff-fix
        files: ^sql/.*\.sql$

  # ---------------------------------------------------------------------------
  # Secret scanning — detect accidentally committed secrets
  # ---------------------------------------------------------------------------
  - repo: https://github.com/gitleaks/gitleaks
    rev: v8.18.2
    hooks:
      - id: gitleaks

  # ---------------------------------------------------------------------------
  # TDD enforcement — block commits where src/ changed without tests
  # ---------------------------------------------------------------------------
  - repo: local
    hooks:
      - id: tdd-check
        name: TDD Check — src changes require test changes
        entry: hooks/pre-commit-tdd-check.sh
        language: script
        pass_filenames: false
        stages: [commit]

  # ---------------------------------------------------------------------------
  # General quality hooks
  # ---------------------------------------------------------------------------
  - repo: https://github.com/pre-commit/pre-commit-hooks
    rev: v4.6.0
    hooks:
      - id: trailing-whitespace
      - id: end-of-file-fixer
      - id: check-yaml
      - id: check-toml
      - id: check-json
      - id: check-merge-conflict
      - id: check-added-large-files
        args: [--maxkb=500]
      - id: mixed-line-ending
        args: [--fix=lf]
      - id: no-commit-to-branch
        args: [--branch, main]
